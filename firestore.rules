rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user owns the cafe
    function isCafeOwner(cafeId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cafeId == cafeId;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own document
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Only admin can create/update users
      allow write: if isAdmin();
      // Allow user to update their own non-role fields
      allow update: if isAuthenticated() && 
        request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'cafeId']);
    }
    
    // Cafes collection
    // paymentSettings (including keyId / keySecret) is stored as a nested map here.
    // Only the cafe owner or admin can read — public ordering page only reads
    // non-sensitive fields (name, logo, primaryColor, etc.) which is acceptable
    // because Firestore document-level rules cannot restrict individual fields.
    // For production, move keySecret to a Cloud Function / Secret Manager.
    match /cafes/{cafeId} {
      // Anyone can read cafe info (for public ordering page)
      allow read: if true;
      // Only cafe owner or admin can update
      allow update: if isCafeOwner(cafeId) || isAdmin();
      // Only admin can create/delete cafes
      allow create, delete: if isAdmin();
    }
    
    // Menu items collection
    match /menuItems/{itemId} {
      // Anyone can read menu items (for public ordering page)
      allow read: if true;
      // Only cafe owner or admin can write
      allow create, update, delete: if 
        isAdmin() || 
        (isAuthenticated() && isCafeOwner(resource.data.cafeId)) ||
        (isAuthenticated() && isCafeOwner(request.resource.data.cafeId));
    }
    
    // Orders collection
    match /orders/{orderId} {
      // Anyone can create orders (customers don't need auth)
      allow create: if true;
      // Cafe owner can read their orders, admin can read all
      // Kitchen Display also reads orders by cafeId — it is a public URL (no auth)
      allow read: if isAdmin() || 
        (isAuthenticated() && isCafeOwner(resource.data.cafeId)) ||
        true; // Kitchen Display screen is public — read allowed for cafeId-scoped queries
      // Cafe owner, admin, OR kitchen display (unauthenticated) can update orderStatus
      // The kitchen screen only ever writes orderStatus + audit timestamp fields
      allow update: if isAdmin() || 
        (isAuthenticated() && isCafeOwner(resource.data.cafeId)) ||
        true; // Kitchen Display needs to advance order status without auth session
      // Only admin can delete orders
      allow delete: if isAdmin();
    }
    
    // Offers collection
    match /offers/{offerId} {
      // Anyone can read active offers (for public ordering page)
      allow read: if true;
      // Only cafe owner or admin can write
      allow create, update, delete: if 
        isAdmin() || 
        (isAuthenticated() && isCafeOwner(resource.data.cafeId)) ||
        (isAuthenticated() && isCafeOwner(request.resource.data.cafeId));
    }
    
    // System collection (counters, etc.)
    match /system/{docId} {
      // Anyone can read/write counters (for order numbering)
      allow read, write: if true;
    }

    // ── Feature 1: Invoices collection ──
    match /invoices/{invoiceId} {
      // Customers can create invoices (invoice is generated client-side after order)
      allow create: if true;
      // Cafe owner can read their invoices; admin can read all
      allow read: if isAdmin() ||
        (isAuthenticated() && isCafeOwner(resource.data.cafeId));
      // Cafe owner or admin can update invoice (e.g. mark paid)
      allow update: if isAdmin() ||
        (isAuthenticated() && isCafeOwner(resource.data.cafeId));
      // Only admin can delete invoices
      allow delete: if isAdmin();
    }

    // ── Feature 5: Inventory collection ──
    match /inventory/{itemId} {
      // Cafe owner and admin can read inventory
      allow read: if isAdmin() ||
        (isAuthenticated() && isCafeOwner(resource.data.cafeId));
      // Cafe owner can create inventory items
      allow create: if isAdmin() ||
        (isAuthenticated() && isCafeOwner(request.resource.data.cafeId));
      // Cafe owner can update (includes stock deductions triggered after orders)
      // Also allow unauthenticated writes for client-side stock deduction on order placement
      allow update: if isAdmin() ||
        (isAuthenticated() && isCafeOwner(resource.data.cafeId)) ||
        true; // stock deduction from customer order page (non-authenticated)
      // Only cafe owner or admin can delete
      allow delete: if isAdmin() ||
        (isAuthenticated() && isCafeOwner(resource.data.cafeId));
    }

    // ── Recipes collection ──
    match /recipes/{menuItemId} {
      // Public read — ordering page fetches recipes for stock deduction
      allow read: if true;
      // Only cafe owner or admin can write recipes
      allow create, update: if isAdmin() ||
        (isAuthenticated() && isCafeOwner(request.resource.data.cafeId));
      allow delete: if isAdmin() ||
        (isAuthenticated() && isCafeOwner(resource.data.cafeId));
    }

    // ── systemConfig — admin only (encrypted API keys) ──
    match /systemConfig/{docId} {
      allow read, write: if isAdmin();
    }

    // ── AI Insights cache per café ──
    match /cafes/{cafeId}/aiCache/{docId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && isCafeOwner(cafeId));
      allow write: if true; // written server-side by Cloud Function
    }

    // ── Task 10: Queue collection — Cloud Functions process these ──
    match /queues/{jobId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated(); // cafe owners can enqueue jobs
      allow update: if false;            // only Cloud Functions update status
      allow delete: if isAdmin();
    }

    // ── Task 10: WhatsApp send logs ──
    match /whatsappLogs/{logId} {
      allow read:  if isAdmin() || (isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cafeId ==
        resource.data.cafeId);
      allow write: if false; // written only by Cloud Functions
    }

    // ── Task 14: New café subcollections (systemType = "new") ──
    match /cafes/{cafeId}/orders/{orderId} {
      allow create: if true;
      allow read:   if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    match /cafes/{cafeId}/menu/{itemId} {
      allow read:   if true;
      allow create, update: if isAdmin() || (isAuthenticated() && isCafeOwner(cafeId));
      allow delete: if isAdmin() || (isAuthenticated() && isCafeOwner(cafeId));
    }

    match /cafes/{cafeId}/inventory/{itemId} {
      allow read:   if isAdmin() || (isAuthenticated() && isCafeOwner(cafeId));
      allow write:  if isAdmin() || (isAuthenticated() && isCafeOwner(cafeId));
    }

    match /cafes/{cafeId}/recipes/{recipeId} {
      allow read:   if true;
      allow write:  if isAdmin() || (isAuthenticated() && isCafeOwner(cafeId));
    }
    // ── WhatsApp Campaigns — written by Admin SDK backend, read by cafe owner ──
    match /whatsapp_campaigns/{campaignId} {
      // Cafe owner can read their own campaigns (for live progress + history)
      allow read: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cafeId ==
        resource.data.cafeId;
      // Only backend (Admin SDK) writes — client cannot create or modify
      allow create, update, delete: if false;
    }

    // ── Staff Management collections ──────────────────────────────────────────
    match /staff/{staffId} {
      allow read:   if isAdmin() || (isAuthenticated() && isCafeOwner(resource.data.cafeId));
      allow create: if isAdmin() || (isAuthenticated() && isCafeOwner(request.resource.data.cafeId));
      allow update: if isAdmin() || (isAuthenticated() && isCafeOwner(resource.data.cafeId));
      allow delete: if isAdmin();
    }

    match /attendance/{recordId} {
      // Allow unauthenticated create — QR scan happens on staff tablet without owner login
      allow create: if true;
      allow read:   if isAdmin() || (isAuthenticated() && isCafeOwner(resource.data.cafeId));
      allow update: if true; // check-out updates from staff tablet
      allow delete: if isAdmin();
    }

    match /salary/{salaryId} {
      allow read:   if isAdmin() || (isAuthenticated() && isCafeOwner(resource.data.cafeId));
      allow create: if isAdmin() || (isAuthenticated() && isCafeOwner(request.resource.data.cafeId));
      allow update: if isAdmin() || (isAuthenticated() && isCafeOwner(resource.data.cafeId));
      allow delete: if isAdmin();
    }
  }
}
